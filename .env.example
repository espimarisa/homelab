# General container configuration.
# DOCKER_IPV6_ULA_BASE: IPV6 ULA base to use for Docker. Must match /etc/docker/daemon.json.
# PGID: Group ID to run containers as.
# PUID: User ID to run containers as.
# RENDER_PGID: Host render GID; used for transcoding. $ getent group render
# TZ: Timezone to use. $ cat /etc/timezone
# UMASK: Default umask to apply to newly created files.
DOCKER_IPV6_ULA_BASE="fdad:21b2:bca9"
PGID="1000"
PUID="1000"
RENDER_PGID=""
TZ="America/New_York"
UMASK="022"

# Storage and directory configuration.
# DOWNLOADS_PATH: Completed downloads path.
# DOWNLOADS_INCOMPLETE_PATH: Incomplete download path, maybe a feeder SSD?
# DOWNLOADS_PERMASEED_PATH: Permaseed-categorized download path, maybe a dedicated beater HDD?
# IMMICH_UPLOADS_PATH: Immich user upload path.
# MEDIA_LIBRARY_PATH: Media library path.
# OPENCLOUD_UPLOADS_PATH: OpenCloud user upload path.
DOWNLOADS_PATH="/storage/downloads"
DOWNLOADS_INCOMPLETE_PATH="/downloads-incomplete"
DOWNLOADS_PERMASEED_PATH="/downloads-permaseed"
IMMICH_UPLOADS_PATH="/storage/appdata/immich"
MEDIA_LIBRARY_PATH="/storage/media-library"
OPENCLOUD_UPLOADS_PATH="/storage/appdata/opencloud"

# Caddy, domain, and URL configuration.
# CLOUDFLARE_TOKEN: Scoped Cloudflare token with DNS editing permissions to $DOMAIN/$INTERNAL_DOMAIN.
# DOMAIN: Domain to use for external access.
# DDNS_DOMAINS: List of dynamic DNS domains to use.
# INTERNAL_DOMAIN: Internal domain or subdomain of $DOMAIN used for internal services.
# ACME_EMAIL: Email to use for ACME DNS challenges.
CLOUDFLARE_TOKEN=""
DOMAIN="example.com"
DDNS_DOMAINS="${DOMAIN} go status photos jellyfin miniflux navidrome cloud search seerr syncplay vault"
INTERNAL_DOMAIN="internal.${DOMAIN}"
ACME_EMAIL="webmaster@${DOMAIN}"
CHHOTO_URL="go.${DOMAIN}"
GATUS_URL="status.${DOMAIN}"
HOMARR_URL="${DOMAIN}"
IMMICH_URL="photos.${DOMAIN}"
JELLYFIN_URL="jellyfin.${DOMAIN}"
MINIFLUX_URL="miniflux.${DOMAIN}"
NAVIDROME_URL="navidrome.${DOMAIN}"
OPENCLOUD_URL="cloud.${DOMAIN}"
SEARXNG_URL="search.${DOMAIN}"
SEERR_URL="seerr.${DOMAIN}"
SYNCPLAY_URL="syncplay.${DOMAIN}"
VAULTWARDEN_URL="vault.${DOMAIN}"

# External SMTP server configuration.
# SMTP_HOST: Server hostname.
# SMTP_PASSWORD: Server password.
# SMTP_PORT: Server port.
# SMTP_SECURITY: starttls, force_tls, or none.
# SMTP_SENDER: username@domain.com
# SMTP_TRANSPORT_ENCRYPTION: starttls, ssltls, or none.
# SMTP_USERNAME: Server username.
SMTP_HOST=""
SMTP_PASSWORD=""
SMTP_PORT="587"
SMTP_SECURITY="starttls"
SMTP_SENDER="webmaster@${DOMAIN}"
SMTP_TRANSPORT_ENCRYPTION="starttls"
SMTP_USERNAME=""

# Password and API key configuration.
# ARR_DB_PASSWORD: 'ARR PostgreSQL password.
# GATUS_DB_PASSWORD: Gatus PostgreSQL password.
# IMMICH_DB_PASSWORD: Immich PostgreSQL password.
# IMMICH_REDIS_PASSWORD: Immich Redis password.
# MINIFLUX_ADMIN_PASSWORD: Miniflux administrator password.
# MINIFLUX_DB_PASSWORD: Miniflux PostgreSQL password.
# SEARXNG_REDIS_PASSWORD: SearXNG redis password.
# SEARXNG_SECRET_KEY: SearXNG secret key. $ openssl rand -hex 32
# SYNCPLAY_PASSWORD: Syncplay password to use.
# VAULTWARDEN_DB_PASSWORD: Vaultwarden PostgreSQL password.
# OPENCLOUD_ADMIN_PASSWORD: OpenCloud administrator password.
# OPENCLOUD_SHARING_JWT: OpenCloud sharing JWT. $ openssl rand -base64 32
# CHHOTO_PASSWORD: Chhoto URL administrator password.
# CHHOTO_API_KEY: Chhoto URL API key. $ openssl rand -base64 32
# GLUETUN_API_KEY: Gluetun API key. $ openssl rand -base64 32
# BAZARR_API_KEY: Bazarr API key, get from Settings -> General after first run.
# LIDARR_API_KEY: Lidarr API key, get from Settings -> General after first run.
# PROWLARR_API_KEY: Prowlarr API key, get from Settings -> General after first run.
# RADARR_API_KEY: Radarr API key, get from Settings -> General after first run.
# SONARR_API_KEY: Sonarr API key, get from Settings -> General after first run.
# FANARTTV_API_KEY: Fanart.tv API key. https://fanart.tv/get-an-api-key/
# GENIUS_API_KEY: Genius user API key. https://genius.com/api-clients
# LASTFM_API_KEY: Last.fm API key. https://www.last.fm/api/account/create
# LASTFM_API_SECRET: Last.fm API secret. https://www.last.fm/api/account/create
ARR_DB_PASSWORD=""
GATUS_DB_PASSWORD=""
IMMICH_DB_PASSWORD=""
IMMICH_REDIS_PASSWORD=""
MINIFLUX_ADMIN_PASSWORD=""
MINIFLUX_DB_PASSWORD=""
SEARXNG_REDIS_PASSWORD=""
SEARXNG_SECRET_KEY=""
SYNCPLAY_PASSWORD=""
VAULTWARDEN_DB_PASSWORD=""
OPENCLOUD_ADMIN_PASSWORD=""
OPENCLOUD_SHARING_JWT=""
CHHOTO_PASSWORD=""
CHHOTO_API_KEY=""
GLUETUN_API_KEY=""
BAZARR_API_KEY=""
LIDARR_API_KEY=""
PROWLARR_API_KEY=""
RADARR_API_KEY=""
SONARR_API_KEY=""
FANARTTV_API_KEY=""
GENIUS_API_KEY=""
LASTFM_API_KEY=""
LASTFM_API_SECRET=""

# Webhook configuration.
# BEETS_DISCORD_WEBHOOK_URL: Beets Discord webhook URL.
# GATUS_DISCORD_WEBHOOK_URL: Gatus Discord webhook URL.
BEETS_DISCORD_WEBHOOK_URL=""
GATUS_DISCORD_WEBHOOK_URL=""

# Beszel Agent configuration. Provided by the Beszel hub on first run.
# BESZEL_KEY: Beszel SSH key to authenticate with.
# BESZEL_TOKEN: Beszel token to authenticate with.
BESZEL_KEY=""
BESZEL_TOKEN=""

# Gluetun configuration. Example values set for my AirVPN. See https://github.com/qdm12/gluetun-wiki
# FIREWALL_OUTBOUND_SUBNETS: List of subnets allowed to access the internal firewall.
# FIREWALL_VPN_INPUT_PORTS: List of ports forwarded from the VPN side (i.e AirVPN static ports).
# SERVER_CITIES: VPN server cities to connect to.
# SERVER_COUNTRIES: VPN server countries to connect to.
# SERVER_REGIONS: VPN server regions to connect to.
# WIREGUARD_ADDRESSES: Wireguard Address(es) to connect to.
# WIREGUARD_ENDPOINT_PORT: Wireguard endpoint point to connect to.
# WIREGUARD_PRESHARED_KEY: PresharedKey from wg0.conf.
# WIREGUARD_PRIVATE_KEY: PrivateKey from wg0.conf.
# WIREGUARD_PUBLIC_KEY: PublicKey from wg0.conf.
FIREWALL_OUTBOUND_SUBNETS="172.19.1.0/24,172.19.2.0/24,172.19.3.0/24"
FIREWALL_VPN_INPUT_PORTS="55536,55537"
SERVER_CITIES="Chicago Illinois,Toronto Ontario,Atlanta Georgia,New York City"
SERVER_COUNTRIES="United States,Canada"
SERVER_REGIONS="America"
WIREGUARD_ADDRESSES=""
WIREGUARD_ENDPOINT_PORT=""
WIREGUARD_PRESHARED_KEY=""
WIREGUARD_PRIVATE_KEY=""
WIREGUARD_PUBLIC_KEY=""

# Navidrome configuration.
# NAVIDROME_ENCRYPTION_KEY: Encryption key to sign Navidrome sessions.
# NAVIDROME_WELCOME_MESSAGE: Custom welcome message to set.
NAVIDROME_ENCRYPTION_KEY=""
NAVIDROME_WELCOME_MESSAGE="Welcome to Navidrome!"

# Soulseek configuration.
# SLSKD_API_KEY: slskd API key to set. $ openssl rand -hex 16
# SLSKD_DOWNLOAD_SPEED_LIMIT: Soulseek download speed cap, in kibibytes.
# SLSKD_JWT_KEY: slskd JWT key for signing secrets. $ openssl rand -base64 32
# SLSKD_PASSWORD: slskd web interface password.
# SLSKD_UPLOAD_SPEED_LIMIT: Soulseek upload speed cap, in kibibytes.
# SLSKD_USERNAME: slskd web interface username.
# SOULSEEK_PASSWORD: Soulseek password to login with.
# SOULSEEK_PORT: Soulseek traffic port to use. Match with your assigned VPN's static port if given.
# SOULSEEK_USER_DESCRIPTION: Soulseek user description to set.
# SOULSEEK_USERNAME: Soulseek username to login with.
SLSKD_API_KEY=""
SLSKD_DOWNLOAD_SPEED_LIMIT="35000"
SLSKD_JWT_KEY=""
SLSKD_PASSWORD="slskd"
SLSKD_UPLOAD_SPEED_LIMIT="35000"
SLSKD_USERNAME="slskd"
SOULSEEK_PASSWORD=""
SOULSEEK_PORT="50300"
SOULSEEK_USER_DESCRIPTION=""
SOULSEEK_USERNAME=""

# Syncplay configuration.
# SYNCPLAY_MOTD: Syncplay MOTD to use.
SYNCPLAY_MOTD="A Syncplay server."

# Vaultwarden configuration.
# VAULTWARDEN_ADMIN_TOKEN: https://github.com/dani-garcia/vaultwarden/wiki/Enabling-admin-page#secure-the-admin_token
# VAULTWARDEN_PUSH_INSTALLATION_ID: https://bitwarden.com/host
# VAULTWARDEN_PUSH_INSTALLATION_KEY: https://bitwarden.com/host
# VAULTWARDEN_SIGNUPS: If true, allows public registrations. Defaults to false; create users at $VAULTWARDEN_URL/admin.
# YUBICO_CLIENT_ID: YubiKey support; client ID from https://upgrade.yubico.com/getapikey
# YUBICO_SECRET_KEY: YubiKey support; secret from https://upgrade.yubico.com/getapikey
VAULTWARDEN_ADMIN_TOKEN=''
VAULTWARDEN_PUSH_INSTALLATION_ID=""
VAULTWARDEN_PUSH_INSTALLATION_KEY=""
VAULTWARDEN_SIGNUPS="false"
YUBICO_CLIENT_ID=""
YUBICO_SECRET_KEY=""
