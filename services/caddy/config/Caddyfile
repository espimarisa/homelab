{
	# Use Cloudflare for ACME DNS challenges.
	acme_dns cloudflare {$CLOUDFLARE_TOKEN}
	email {$ACME_EMAIL}

	# Configures trusted proxies for Cloudflare support.
	servers {
		trusted_proxies cloudflare
		client_ip_headers CF-Connecting-IP X-Forwarded-For X-Real-IP
	}
}

# Snippet for common options and headers.
(common_options) {
	# Enable compression.
	encode zstd gzip

	# Enables HSTS and sets common headers.
	header {
		-Server
		Referrer-Policy "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
	}
}

# Snippet for reverse proxying external services.
(external_proxy) {
	# Import common settings and headers.
	import common_options

	# Reverse proxy.
	reverse_proxy {args[0]}
}

# Snippet for reverse proxying external services (proxied through Cloudflare).
(cloudflare_proxy) {
	# Import common settings and headers.
	import common_options

	# Reverse proxy and pass the actual client IP.
	reverse_proxy {args[0]} {
		header_up X-Real-IP {client_ip}
	}
}

# Snippet for reverse proxying internal services. Accessible with a DNS rewrite.
(internal_proxy) {
	# Import common options and headers.
	import common_options

	# Abort traffic not from private ranges (plus Tailscale).
	@denied not remote_ip private_ranges 100.64.0.0/10 fd7a:115c:a1e0::/48
	abort @denied

	# Reverse proxy.
	reverse_proxy {args[0]}
}

# Drop all unhandled traffic.
* {
	handle {
		abort
	}

	# Drop all access logs to stop spamming logs.
	log {
		output discard
	}
}

# Internal healthcheck endpoint.
:3000 {
	# Drop all access logs to stop spamming logs.
	log {
		output discard
	}

	respond "OK" 200
}

# Externally accessible services.
# These should all have DNS record set in $DOMAIN.
# If using Cloudflare, do not enable proxying for these.

# Immich web interface.
{$IMMICH_URL} {
	import external_proxy immich:2283
}

# Jellyfin web interface.
{$JELLYFIN_URL} {
	import external_proxy jellyfin:8096
}

# OpenCloud web interface.
{$OPENCLOUD_URL} {
	import external_proxy opencloud:9200
}

# Externally accessible services (proxied with Cloudflare).
# These should all have DNS record set in $DOMAIN.
# If using Cloudflare, enable proxying for these.

# Chhoto URL web interface.
{$CHHOTO_URL} {
	import cloudflare_proxy chhoto:4567
}

# Gatus status page.
{$GATUS_URL} {
	import cloudflare_proxy gatus:8080
}

# Homarr.
{$HOMARR_URL} {
	import cloudflare_proxy homarr:7575
}

# Seerr.
{$SEERR_URL} {
	import cloudflare_proxy seerr:5055
}

# Vaultwarden web interface; admin page is $VAULTWARDEN_URL/admin.
{$VAULTWARDEN_URL} {
	import cloudflare_proxy vaultwarden:80
}

# Internally accessible services.
# Accessible with a DNS rewrite (i.e *.$INTERNAL_DOMAIN -> 192.x.x.x).
# Do not have a DNS record set for these, ever!

# Backrest web interface.
backrest.{$INTERNAL_DOMAIN} {
